      "id": "node-route",
      "name": "Route Messages",
      "position": [
        912,
        320
      ],
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3
    },
    {
      "parameters": {
        "jsCode": "// Split messages with multiple requirements into separate entries\n// Uses timestamp-based unique MSG-IDs\nfunction generateMsgId() {\n  return 'MSG-' + Date.now() + '-' + Math.floor(Math.random() * 10000);\n}\n\nconst output = [];\n\nfor (const item of $input.all()) {\n  const rawMessage = String(item.json.rawMessage || '');\n  const baseId = String(item.json.messageId || '').trim();\n\n  const lines = rawMessage.split(/[\\n\\r]+/).filter(l => l.trim().length > 0);\n\n  const requirementIndicators = [\n    /^\\d+[.)]/,\n    /^[-\u2022\u25cf\u25aa]/,\n    /^[a-z][.)]/i\n  ];\n\n  const segments = [];\n  let currentSegment = '';\n\n  for (const line of lines) {\n    const trimmed = line.trim();\n    const isNewRequirement = requirementIndicators.some(r => r.test(trimmed));\n\n    if (isNewRequirement && currentSegment.trim()) {\n      segments.push(currentSegment.trim());\n      currentSegment = trimmed;\n    } else {\n      currentSegment += (currentSegment ? '\\n' : '') + trimmed;\n    }\n  }\n  if (currentSegment.trim()) {\n    segments.push(currentSegment.trim());\n  }\n\n  if (segments.length > 1) {\n    for (let i = 0; i < segments.length; i++) {\n      output.push({\n        json: {\n          messageId: generateMsgId(),\n          originalMessageId: baseId,\n          rawMessage: segments[i],\n          status: 'RELEVANT',\n          skipReason: ''\n        }\n      });\n    }\n  } else {\n    const finalId = (baseId && baseId !== '' && baseId !== 'undefined') ? baseId : generateMsgId();\n    output.push({\n      json: {\n        messageId: finalId,\n        originalMessageId: baseId,\n        rawMessage: rawMessage,\n        status: 'RELEVANT',\n        skipReason: ''\n      }\n    });\n  }\n}\n\nreturn output;"
      },
      "id": "node-split",
      "name": "Split Multi Requirements",
      "position": [
        1168,
        224
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://127.0.0.1:11434/api/generate",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"llama3\",\n  \"prompt\": \"You are a real estate data extractor. Extract structured data from this property message.\\n\\nMessage: {{ $json.rawMessage }}\\n\\nReturn ONLY this JSON, no extra text:\\n{\\n  \\\"locality_project\\\": \\\"\\\",\\n  \\\"property_type\\\": \\\"\\\",\\n  \\\"size\\\": \\\"\\\",\\n  \\\"facing_feature\\\": \\\"\\\",\\n  \\\"price_budget\\\": \\\"\\\",\\n  \\\"furnishing\\\": \\\"\\\",\\n  \\\"contact_name\\\": \\\"\\\",\\n  \\\"contact_number\\\": \\\"\\\"\\n}\\n\\nRules:\\n- Use \\\"Not Available\\\" if a field is not found in the message\\n- property_type MUST be one of: Apartment, Plot, Commercial, Builder Floor, Villa\\n- Return ONLY the JSON object, nothing else\",\n  \"stream\": false\n}",
        "options": {
          "timeout": 120000
        }
      },
      "id": "node-ai",
      "name": "Extract with Ollama AI",
      "position": [
        1408,
        224
      ],
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "// SAFE JSON PARSING - No regex, try/catch only\n// Output: status = RELEVANT (success) or FAILED (parse error)\n// All missing values = \"Not Available\" (never \"NA\")\n// All values prefixed with ' for Google Sheets safety\n\nconst validPropertyTypes = ['Apartment', 'Plot', 'Commercial', 'Builder Floor', 'Villa'];\nconst fieldKeys = [\n  'locality_project', 'property_type', 'size',\n  'facing_feature', 'price_budget', 'furnishing',\n  'contact_name', 'contact_number'\n];\n\nfunction generateMsgId() {\n  return 'MSG-' + Date.now() + '-' + Math.floor(Math.random() * 10000);\n}\n\n// Clean value: trim, remove emojis/symbols, normalize\nfunction cleanFieldValue(val) {\n  if (val === null || val === undefined) return \"'Not Available\";\n  let s = String(val).trim();\n  // Remove emojis and decorative symbols\n  s = s.replace(/[\\u{1F600}-\\u{1F64F}\\u{1F300}-\\u{1F5FF}\\u{1F680}-\\u{1F6FF}\\u{1F1E0}-\\u{1F1FF}\\u{2600}-\\u{26FF}\\u{2700}-\\u{27BF}]/gu, '').trim();\n  s = s.replace(/[*~^|]/g, '').trim();\n  // Normalize spacing\n  s = s.replace(/\\s+/g, ' ');\n  if (s === '' || s.toUpperCase() === 'NA' || s.toUpperCase() === 'N/A' || s === 'null' || s === 'undefined') {\n    return \"'Not Available\";\n  }\n  return \"'\" + s;\n}\n\nconst results = [];\n\nfor (const item of $input.all()) {\n  // Ensure valid Message ID \u2014 never MSG-UNKNOWN\n  let messageId = String(item.json.messageId || item.json.message_id || '').trim();\n  if (!messageId || messageId === '' || messageId === 'MSG-UNKNOWN' || messageId === 'undefined') {\n    messageId = generateMsgId();\n  }\n\n  const rawMessage = String(item.json.rawMessage || '');\n  const rawResponse = String(item.json.response || '');\n  let parsed = null;\n  let parseError = false;\n\n  // Try/catch safe JSON parsing \u2014 NO regex\n  try {\n    parsed = JSON.parse(rawResponse);\n  } catch (e1) {\n    try {\n      const startIdx = rawResponse.indexOf('{');\n      const endIdx = rawResponse.lastIndexOf('}');\n      if (startIdx !== -1 && endIdx !== -1 && endIdx > startIdx) {\n        const jsonStr = rawResponse.substring(startIdx, endIdx + 1);\n        parsed = JSON.parse(jsonStr);\n      } else {\n        parseError = true;\n      }\n    } catch (e2) {\n      parseError = true;\n    }\n  }\n\n  if (parseError || !parsed || typeof parsed !== 'object') {\n    // AI parsing FAILED \u2014 fill all fields with fallback\n    const row = {\n      message_id: \"'\" + messageId,\n      rawMessage: rawMessage,\n      status: \"'FAILED\",\n      skip_reason: \"'AI parsing failed\",\n      _isFailed: true\n    };\n    for (const key of fieldKeys) {\n      row[key] = \"'Not Available\";\n    }\n    results.push({ json: row });\n  } else {\n    // Validate property_type\n    let propType = String(parsed.property_type || '').trim();\n    if (!validPropertyTypes.includes(propType)) {\n      propType = 'Not Available';\n    }\n\n    results.push({\n      json: {\n        message_id: \"'\" + messageId,\n        rawMessage: rawMessage,\n        locality_project: cleanFieldValue(parsed.locality_project),\n        property_type: \"'\" + propType,\n        size: cleanFieldValue(parsed.size),\n        facing_feature: cleanFieldValue(parsed.facing_feature),\n        price_budget: cleanFieldValue(parsed.price_budget),\n        furnishing: cleanFieldValue(parsed.furnishing),\n        contact_name: cleanFieldValue(parsed.contact_name),\n        contact_number: cleanFieldValue(parsed.contact_number),\n        status: \"'RELEVANT\",\n        skip_reason: \"'\",\n        _isFailed: false\n      }\n    });\n  }\n}\n\nreturn results;"
      },
