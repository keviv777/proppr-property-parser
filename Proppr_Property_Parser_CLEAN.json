    {
      "parameters": {
        "jsCode": "// Filter out non-property messages, clean data, generate MSG-IDs\nconst skipKeywords = [\n  'hiring', 'job', 'salary', 'incentive', 'offer',\n  'promotion', 'gemini', 'storage', 'credits'\n];\n\n// Data cleaning function \u2014 remove emojis, symbols, normalize spacing\nfunction cleanText(text) {\n  if (!text) return '';\n  let cleaned = String(text);\n  // Remove emojis and special unicode symbols\n  cleaned = cleaned.replace(/[\\u{1F600}-\\u{1F64F}\\u{1F300}-\\u{1F5FF}\\u{1F680}-\\u{1F6FF}\\u{1F1E0}-\\u{1F1FF}\\u{2600}-\\u{26FF}\\u{2700}-\\u{27BF}\\u{FE00}-\\u{FE0F}\\u{1F900}-\\u{1F9FF}\\u{1FA00}-\\u{1FA6F}\\u{1FA70}-\\u{1FAFF}\\u{200D}\\u{20E3}\\u{E0020}-\\u{E007F}]/gu, '');\n  // Remove decorative symbols like *, ~, but keep hyphens and slashes\n  cleaned = cleaned.replace(/[*~#^|]/g, '');\n  // Normalize whitespace\n  cleaned = cleaned.replace(/\\s+/g, ' ').trim();\n  return cleaned;\n}\n\n// Generate unique MSG-ID\nfunction generateMsgId() {\n  return 'MSG-' + Date.now() + '-' + Math.floor(Math.random() * 1000);\n}\n\nconst results = [];\n\nfor (const item of $input.all()) {\n  const rawMessage = cleanText(item.json['Raw Message'] || '');\n  let messageId = String(item.json['Message ID'] || '').trim();\n  const status = String(item.json['Status'] || '').trim().toUpperCase();\n\n  // Skip already processed rows\n  if (status === 'DONE') continue;\n\n  // Ensure valid Message ID\n  if (!messageId || messageId === '' || messageId === 'undefined' || messageId === 'null') {\n    messageId = generateMsgId();\n  }\n\n  const lowerMsg = rawMessage.toLowerCase();\n  let skipReason = '';\n\n  for (const kw of skipKeywords) {\n    if (lowerMsg.includes(kw)) {\n      skipReason = 'Contains irrelevant keyword: \"' + kw + '\"';\n      break;\n    }\n  }\n\n  if (skipReason) {\n    results.push({\n      json: {\n        messageId: messageId,\n        rawMessage: rawMessage,\n        status: 'SKIP',\n        skipReason: skipReason\n      }\n    });\n  } else {\n    results.push({\n      json: {\n        messageId: messageId,\n        rawMessage: rawMessage,\n        status: 'RELEVANT',\n        skipReason: ''\n      }\n    });\n  }\n}\n\nreturn results;"
      },
      "id": "node-filter",
      "name": "Filter and Classify",
      "position": [
        672,
        320
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "parameters": {
        "conditions": {
          "combinator": "and",
          "conditions": [
            {
              "id": "cond-relevant",
              "leftValue": "={{ $json.status }}",
              "operator": {
